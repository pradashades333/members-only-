<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members Only</title>
    <style>
        * { box-sizing: border-box; }

        body {
            background: linear-gradient(135deg, mediumpurple, indigo);
            min-height: 100vh;
            font-family: Arial;
            margin: 0;
            padding: 20px;
        }

        h1 {
            color: white;
            text-align: center;
            letter-spacing: 2px;
            font-size: 1.8em;
            margin-bottom: 5px;
            text-shadow: 1px 1px 4px rgba(0,0,0,0.3);
        }

        .nav {
            text-align: center;
            margin: 10px 0;
        }

        .nav a {
            margin: 0 8px;
            color: white;
            font-weight: bold;
            text-decoration: none;
            font-size: 0.95em;
            opacity: 0.9;
        }

        .nav a:hover {
            opacity: 1;
            text-decoration: underline;
        }

        hr {
            border: none;
            border-top: 1px solid rgba(255,255,255,0.3);
            margin: 12px auto;
            width: 80%;
        }

        .messages-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            padding: 10px;
        }

        .message-box {
            background-color: white;
            border-left: 4px solid indigo;
            border-radius: 8px;
            padding: 15px 20px;
            width: 520px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.2);
        }

        .message-box h2 {
            margin: 0 0 8px 0;
            color: indigo;
            font-size: 1.05em;
        }

        .message-box p {
            margin: 4px 0;
            color: #333;
            font-size: 0.95em;
            line-height: 1.5;
        }

        .message-meta {
            font-size: 0.8em;
            color: #888;
            margin-top: 10px;
            border-top: 1px solid #eee;
            padding-top: 8px;
        }

        button {
            background-color: crimson;
            color: white;
            border: none;
            padding: 4px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.8em;
            margin-top: 10px;
        }

        button:hover {
            background-color: darkred;
        }
    </style>
</head>
<body>

    <h1>Members Only Club</h1>

    <div class="nav">
        <% if (user) { %>
            <a href="/new-message">+ New Message</a> |
            <a href="/log-out">Log Out</a>
        <% } else { %>
            <a href="/sign-up">Sign Up</a> |
            <a href="/log-in">Log In</a>
        <% } %>
    </div>

    <hr>

    <div class="messages-container">
    <% messages.forEach(message => { %>
        <div class="message-box">
            <h2><%= message.title %></h2>
            <p><%= message.text %></p>

            <% if (user && user.membership_status) { %>
                <div class="message-meta">
                    <span><b>By:</b> <%= message.first_name %> <%= message.last_name %></span> &nbsp;|&nbsp;
                    <span><b>Posted:</b> <%= message.created_at %></span>
                </div>
            <% } %>

            <% if (user) { %>
                <form action="/message/<%= message.id %>/delete" method="POST">
                    <button type="submit">Delete</button>
                </form>
            <% } %>
        </div>
    <% }) %>
    </div>

</body>
</html>
