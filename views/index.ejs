<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members Only</title>
    <style>
        body {
            background-color: lightblue;
            font-family: Arial;
        }

        h1 {
            color: darkblue;
            text-align: center;
        }

        .messages-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            padding: 10px;
        }

        .message-box {
            background-color: white;
            border: 2px solid darkblue;
            border-radius: 8px;
            padding: 15px 20px;
            width: 500px;
            box-shadow: 2px 2px 6px rgba(0,0,0,0.15);
        }

        .message-box h2 {
            margin: 0 0 8px 0;
            color: darkblue;
            font-size: 1.1em;
        }

        .message-box p {
            margin: 4px 0;
        }

        .message-meta {
            font-size: 0.85em;
            color: gray;
            margin-top: 10px;
            border-top: 1px solid #eee;
            padding-top: 8px;
        }

        .nav {
            text-align: center;
            margin: 10px;
        }

        .nav a {
            margin: 5px;
            color: darkblue;
        }

        button {
            background-color: red;
            color: white;
            border: none;
            padding: 5px 10px;
        }
    </style>
</head>
<body>

    <h1>Members Only Club</h1>

    <div class="nav">
        <% if (user) { %>
            <a href="/new-message">+ Create new message</a> |
            <a href="/log-out">Log Out</a>
        <% } else { %>
            <a href="/sign-up">Sign Up</a> |
            <a href="/log-in">Log In</a>
        <% } %>
    </div>

    <hr>

    <div class="messages-container">
    <% messages.forEach(message => { %>
        <div class="message-box">
            <h2><%= message.title %></h2>
            <p><%= message.text %></p>

            <% if (user && user.membership_status) { %>
                <div class="message-meta">
                    <span><b>By:</b> <%= message.first_name %> <%= message.last_name %></span> &nbsp;|&nbsp;
                    <span><b>Posted:</b> <%= message.created_at %></span>
                </div>
            <% } %>

            <% if (user) { %>
                <form action="/message/<%= message.id %>/delete" method="POST" style="margin-top: 10px;">
                    <button type="submit">Delete</button>
                </form>
            <% } %>
        </div>
    <% }) %>
    </div>

</body>
</html>