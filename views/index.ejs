<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members Only</title>
</head>
<body>
    <div>
        <h1>Messages</h1>

        <% if (user) { %>
            <a href="/new-message">+ Create new message</a>
        <% } %>

        <% messages.forEach(message => { %>
            <div>
                <h2><%= message.title %></h2>
                <p><%= message.text %></p>

                <% if (user && user.membership_status) { %>
                    <p>By: <%= message.first_name %> <%= message.last_name %></p>
                    <p>Posted: <%= message.created_at %></p>
                <% } %>

                <% if (user && user.is_admin) { %>
                    <form action="/message/<%= message.id %>/delete" method="POST">
                        <button type="submit">Delete</button>
                    </form>
                <% } %>
            </div>
        <% }) %>

        <% if (!user) { %>
            <a href="/sign-up">Sign Up</a>
            <a href="/log-in">Log In</a>
        <% } else { %>
            <a href="/log-out">Log Out</a>
        <% } %>
    </div>
</body>
</html>