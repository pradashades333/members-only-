<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members Only</title>
    <style>
        body {
            background-color: lightblue;
            font-family: Arial;
        }

        h1 {
            color: darkblue;
            text-align: center;
        }

        .message-box {
            background-color: white;
            border: 2px solid darkblue;
            padding: 10px;
            margin: 10px;
            width: 400px;
        }

        .nav {
            text-align: center;
            margin: 10px;
        }

        .nav a {
            margin: 5px;
            color: darkblue;
        }

        button {
            background-color: red;
            color: white;
            border: none;
            padding: 5px 10px;
        }
    </style>
</head>
<body>

    <h1>Members Only Club</h1>

    <div class="nav">
        <% if (user) { %>
            <a href="/new-message">+ Create new message</a> |
            <a href="/log-out">Log Out</a>
        <% } else { %>
            <a href="/sign-up">Sign Up</a> |
            <a href="/log-in">Log In</a>
        <% } %>
    </div>

    <hr>

    <% messages.forEach(message => { %>
        <div class="message-box">
            <h2><%= message.title %></h2>
            <p><%= message.text %></p>

            <% if (user && user.membership_status) { %>
                <p><b>By:</b> <%= message.first_name %> <%= message.last_name %></p>
                <p><b>Posted:</b> <%= message.created_at %></p>
            <% } %>

            <% if (user) { %>
                <form action="/message/<%= message.id %>/delete" method="POST">
                    <button type="submit">Delete</button>
                </form>
            <% } %>
        </div>
    <% }) %>

</body>
</html>