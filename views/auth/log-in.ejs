<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log In</title>
    <style>
        body {
            background: linear-gradient(135deg, mediumpurple, indigo);
            font-family: Arial;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .login-box {
            background-color: white;
            border: 2px solid indigo;
            border-radius: 8px;
            padding: 30px 40px;
            width: 300px;
            box-shadow: 2px 2px 6px rgba(0,0,0,0.15);
            text-align: center;
        }

        h1 {
            color: indigo;
            margin-bottom: 20px;
        }

        label {
            display: block;
            text-align: left;
            margin-bottom: 4px;
            font-weight: bold;
            color: indigo;
        }

        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 8px;
            margin-bottom: 15px;
            border: 1px solid indigo;
            border-radius: 4px;
            box-sizing: border-box;
        }

        input[type="submit"] {
            background-color: indigo;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            width: 100%;
            font-size: 1em;
        }

        input[type="submit"]:hover {
            background-color: darkviolet;
        }

        .signup-link {
            margin-top: 15px;
            font-size: 0.9em;
        }

        .signup-link a {
            color: indigo;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <h1>Log In</h1>
        <form action="/log-in" method="POST">
            <label for="email">Email:</label>
            <input type="email" id="email" name="email">

            <label for="password">Password:</label>
            <input type="password" id="password" name="password">

            <input type="submit" value="Log In">
        </form>
        <div class="signup-link">
            Don't have an account? <a href="/sign-up">Sign Up</a>
        </div>
    </div>
</body>
</html>
